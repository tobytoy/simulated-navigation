# =========================================================================
# 1. 交通部 TDX API 憑證 (僅限後端使用，不可加 VITE_ 前綴以防洩漏)
# =========================================================================
TDX_CLIENT_ID="your_tdx_client_id_here"
TDX_CLIENT_SECRET="your_tdx_client_secret_here"
TDX_TOKEN_URL="https://tdx.transportdata.tw/auth/realms/TDXConnect/protocol/openid-connect/token"

# =========================================================================
# 2. Supabase 資料庫與 SDK 設定
# =========================================================================
# 前端公開金鑰 (Vite 會將 VITE_ 開頭的變數打包進前端)
VITE_SUPABASE_URL="https://xxxxxxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# 後端直連 PostgreSQL (pgvector) 與管理金鑰 (僅限後端使用，不可加 VITE_ 前綴)
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxx.supabase.co:5432/postgres"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# =========================================================================
# 3. Firebase 託管與服務設定 (前端使用，Vite 會打包)
# =========================================================================
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-app"
VITE_FIREBASE_STORAGE_BUCKET="your-app.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="12345678"
VITE_FIREBASE_APP_ID="1:1234:web:abcd"

# =========================================================================
# 4. 其他配置
# =========================================================================
# Gemini API Key (用於前端 @google/genai 庫或後端代理)
VITE_GEMINI_API_KEY="your_gemini_api_key_here"
PORT=3000
